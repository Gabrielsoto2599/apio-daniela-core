{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": false,
    "target": "es2020",
    "module": "esnext",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": true
  },
  "include": [
    "apio-conciencia/**/*.ts",
    "apio-conciencia/**/*.tsx",
    "apio-conciencia/server.cjs",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
